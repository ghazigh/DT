# landing_page/.env.example
# Copy to .env.local for dev. Never commit the real .env.local.

# Optional: webhook receiving pilot-request submissions (Slack/Discord/Zapier/Formspree).
# If empty or unset, the API function logs payloads and returns 200 without forwarding.
PILOT_WEBHOOK_URL=

# Optional: Plausible domain to enable analytics. If unset, analytics is disabled.
PUBLIC_ANALYTICS_DOMAIN=
