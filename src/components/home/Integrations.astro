---
// landing_page/src/components/home/Integrations.astro
// Interop and trust strip — what flows in, what flows out, what we're certified for.
const dataIn = [
  'Sentinel-2', 'Planet · SuperDove', 'Maxar · WorldView', 'USGS 3DEP', 'Copernicus', 'Esri ArcGIS', 'OpenStreetMap', 'LiDAR', 'IoT · MQTT'
];
const systemsOut = [
  'IBM Maximo', 'Oracle Utilities', 'SAP PM', 'GE GridOS', 'ServiceNow', 'Power BI', 'Tableau', 'Webhooks', 'REST · GraphQL'
];
const certs = [
  { k: 'SOC 2',         v: 'Type II · in progress' },
  { k: 'NERC FAC-003',  v: 'Audit-ready' },
  { k: 'ISO 27001',     v: 'Controls aligned' },
  { k: 'GDPR · Law 25', v: 'Compliant' }
];
---
<section class="relative" style="border-bottom: 1px solid var(--steel); background: var(--obsidian);">
  <div class="container-page py-24 md:py-32">
    <div class="chapter reveal">
      <span class="num">[ 08 ]</span>
      <span class="rule"></span>
      <span class="label">Interop &amp; trust</span>
    </div>

    <div class="grid lg:grid-cols-12 gap-10 items-end mb-14">
      <h2 class="lg:col-span-7 text-balance reveal">
        Sits <em>above your GIS,</em><br/>under your ops system.
      </h2>
      <p class="lg:col-span-4 lg:col-start-9 reveal" style="color: var(--fog); font-size: 17px; line-height: 1.6; transition-delay: 120ms;">
        No rip-and-replace. The twin ingests the imagery and asset data you already have, and delivers ranked work into the systems your crews already use.
      </p>
    </div>

    <!-- Data in -->
    <div class="py-7 reveal" style="border-top: 1px solid var(--bone); transition-delay: 160ms;">
      <div class="flex items-center gap-6 mb-6">
        <span class="kicker-accent" style="font-size: 10px;">→ data in</span>
        <span class="hairline flex-1"></span>
        <span class="kicker" style="font-size: 10px;">any sensor · any satellite · any layer</span>
      </div>
      <div class="flex flex-wrap gap-x-8 gap-y-3">
        {dataIn.map((n) => (
          <span class="font-display" style="font-size: 22px; font-weight: 600; letter-spacing: -0.015em; color: var(--bone); transition: color 240ms;">{n}</span>
        ))}
      </div>
    </div>

    <!-- Systems out -->
    <div class="py-7 reveal" style="border-top: 1px solid var(--steel); transition-delay: 220ms;">
      <div class="flex items-center gap-6 mb-6">
        <span class="kicker" style="font-size: 10px;">systems out ←</span>
        <span class="hairline flex-1"></span>
        <span class="kicker" style="font-size: 10px;">alerts, work orders, audit reports</span>
      </div>
      <div class="flex flex-wrap gap-x-8 gap-y-3">
        {systemsOut.map((n) => (
          <span class="font-display" style="font-size: 22px; font-weight: 600; letter-spacing: -0.015em; color: var(--bone);">{n}</span>
        ))}
      </div>
    </div>

    <!-- Trust certs -->
    <div class="mt-12 grid md:grid-cols-4 plate reveal" style="transition-delay: 280ms;">
      {certs.map((c, i) => (
        <div
          class="p-6"
          style={`${i < 3 ? 'border-right: 1px solid var(--steel);' : ''} ${i < 2 ? 'border-bottom: 1px solid var(--steel);' : ''}`}
        >
          <p class="kicker-accent" style="font-size: 10px;">{c.k}</p>
          <p class="mt-3 text-sm" style="color: var(--bone);">{c.v}</p>
        </div>
      ))}
    </div>
  </div>
</section>
