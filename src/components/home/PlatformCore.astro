---
// landing_page/src/components/home/PlatformCore.astro
// "One twin, many use cases" — central thesis. Twin in the middle, modules either side.
// Naming follows Branding §3 hierarchy: Sat Lab → Twin → Vegetation Intelligence / Urban Canopy.

const base = import.meta.env.BASE_URL.replace(/\/$/, '');---
<section id="platform-core" class="relative" style="border-bottom: 1px solid var(--steel); background: var(--obsidian);">
  <div class="container-page py-24 md:py-32">
    <div class="chapter reveal">
      <span class="num">[ 03 ]</span>
      <span class="rule"></span>
      <span class="label">The thesis</span>
    </div>

    <div class="grid lg:grid-cols-12 gap-10 items-end mb-16">
      <h2 class="lg:col-span-8 text-balance reveal">
        One twin. <em>Many use cases on top.</em>
      </h2>
      <p class="lg:col-span-4 reveal" style="color: var(--fog); font-size: 17px; line-height: 1.6; transition-delay: 120ms;">
        We ship a single model of the world — assets, terrain, canopy, weather, sensor streams — and layer use-case modules on top. Vegetation pays first; the rest compounds.
      </p>
    </div>

    <!-- Triptych -->
    <div class="relative grid md:grid-cols-3 gap-0 plate reveal" style="transition-delay: 200ms;">
      <!-- Module 01 — Vegetation Intelligence -->
      <a href={`${base}/vegetation`} class="group relative text-left p-10 md:p-12 transition-colors duration-300"
         style="border-right: 1px solid var(--steel);">
        <p class="kicker-accent" style="font-size: 10px;">Module 01 · shipping 2026</p>
        <h3 class="mt-7" style="font-size: 1.875rem; line-height: 1.05;">
          Vegetation<br/>Intelligence
        </h3>
        <p class="mt-7 max-w-sm" style="color: var(--fog); line-height: 1.6;">
          Predicts where vegetation is likely to contact transmission lines within 18 months. Output: a ranked work list per circuit, exportable to your work-management system.
        </p>
        <ul class="mt-7 space-y-2 text-sm" style="color: var(--bone);">
          <li class="flex items-start gap-2"><span class="mark">·</span> Multi-resolution satellite cascade</li>
          <li class="flex items-start gap-2"><span class="mark">·</span> Risk model trained on outage history</li>
          <li class="flex items-start gap-2"><span class="mark">·</span> NERC FAC-003 audit-ready</li>
        </ul>
        <span class="mt-10 btn-link inline-flex">
          Open module
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        </span>
      </a>

      <!-- Twin — core platform -->
      <div class="relative flex flex-col items-center justify-center text-center p-10 md:p-12"
           style="border-right: 1px solid var(--steel); background: var(--slate);">
        <p class="kicker" style="font-size: 10px;">[ Core platform ]</p>
        <h3 class="mt-6 leading-tight" style="font-size: 2.25rem;">
          Sat Lab<br/>
          <span class="mark">Twin</span>
        </h3>

        <!-- Graticule precision emblem (brand symbol direction 1 + 3) -->
        <svg class="mt-8 h-44 w-44" viewBox="0 0 200 200" fill="none" aria-hidden="true">
          <!-- outer ring with degree ticks -->
          <circle cx="100" cy="100" r="92" stroke="#3F4859" stroke-width="0.8" stroke-dasharray="1 4" opacity="0.8"/>
          <circle cx="100" cy="100" r="72" stroke="#3F4859" stroke-width="0.8"/>
          <circle cx="100" cy="100" r="46" stroke="#3F4859" stroke-width="0.8"/>
          <circle cx="100" cy="100" r="22" stroke="#5EE26B" stroke-width="1.4"/>
          <circle cx="100" cy="100" r="3" fill="#5EE26B"/>
          <!-- meridian + parallel -->
          <g stroke="#3F4859" stroke-width="0.8">
            <line x1="100" y1="0"   x2="100" y2="12"/>
            <line x1="100" y1="188" x2="100" y2="200"/>
            <line x1="0"   y1="100" x2="12"  y2="100"/>
            <line x1="188" y1="100" x2="200" y2="100"/>
          </g>
          <!-- orbital arc with traveling sat -->
          <path d="M 18 100 A 82 82 0 0 1 182 100" stroke="#5EE26B" stroke-width="0.8" stroke-dasharray="3 3" opacity="0.6" fill="none"/>
          <circle cx="172" cy="100" r="3.5" fill="#5EE26B">
            <animateTransform attributeName="transform" type="rotate" from="0 100 100" to="360 100 100" dur="22s" repeatCount="indefinite"/>
          </circle>
        </svg>

        <p class="mt-8 max-w-xs text-sm" style="color: var(--fog); line-height: 1.55;">
          Authoritative live model of the physical world. PostGIS · Kafka · CesiumJS · Neo4j.
        </p>

        <a href={`${base}/platform`} class="mt-7 btn-link">Enter platform</a>
      </div>

      <!-- Module 02 — Urban Canopy -->
      <a href={`${base}/urban-canopy`} class="group relative text-left md:text-right p-10 md:p-12 transition-colors duration-300">
        <p class="kicker-accent md:text-right" style="font-size: 10px;">Module 02 · 2026 · pilot</p>
        <h3 class="mt-7 md:text-right" style="font-size: 1.875rem; line-height: 1.05;">
          Urban<br/>Canopy
        </h3>
        <p class="mt-7 max-w-sm md:ml-auto" style="color: var(--fog); line-height: 1.6;">
          A streaming 3-D twin of the urban grid — terrain, parcels, every street tree, weather and risk — as composable layers a city's planners can query.
        </p>
        <ul class="mt-7 space-y-2 text-sm md:text-right" style="color: var(--bone);">
          <li class="md:justify-end flex items-start gap-2"><span class="mark">·</span> Cooling + stormwater + equity ranking</li>
          <li class="md:justify-end flex items-start gap-2"><span class="mark">·</span> Per-tree species + growth model</li>
          <li class="md:justify-end flex items-start gap-2"><span class="mark">·</span> ArcGIS · OSM · custom GIS in</li>
        </ul>
        <span class="mt-10 btn-link inline-flex md:ml-auto">
          Open module
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        </span>
      </a>
    </div>

    <!-- Architecture readout — what the twin is, in one line of mono -->
    <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 reveal" style="transition-delay: 280ms;">
      <span class="kicker" style="font-size: 10px;">Twin stack</span>
      <span class="hairline w-12"></span>
      <code class="font-mono text-xs" style="color: var(--bone);">PostGIS · Kafka · PyTorch · Neo4j · CesiumJS · FastAPI · Airflow</code>
    </div>
  </div>
</section>
