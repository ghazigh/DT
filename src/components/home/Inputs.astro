---
// landing_page/src/components/home/Inputs.astro
// What feeds the twin: real-world high-fidelity data sources.
const sources = [
  {
    n: '01',
    title: 'Satellite imagery',
    body: 'Multi-resolution, every cycle. From 10 m wide-area to sub-meter on demand. RGB, NDVI, SWIR, thermal — every band that helps.',
    icon: 'satellite',
    label: '10 m → 0.3 m'
  },
  {
    n: '02',
    title: 'Real-time traffic',
    body: 'Live mobility feeds, GPS pings, fleet telemetry, public-transit signals. Vehicles, vessels, crews — wherever they move.',
    icon: 'traffic',
    label: 'streaming · sub-minute'
  },
  {
    n: '03',
    title: 'Weather data',
    body: 'Forecasts, hindcasts, radar, lightning, wind fields, fire-weather indices. Both global models and local sensor nets.',
    icon: 'weather',
    label: 'forecast + observed'
  },
  {
    n: '04',
    title: '3D real-world maps',
    body: 'Photogrammetry, LiDAR, BIM, cadastral parcels. Every building, parcel, and asset placed in true 3D.',
    icon: 'mesh',
    label: 'sub-meter geometry'
  },
  {
    n: '05',
    title: 'High-fidelity simulations',
    body: 'Wind, water, fire, structural, network. Multi-level physics that your team can run on demand against the twin.',
    icon: 'sim',
    label: 'physics · multi-level'
  },
  {
    n: '06',
    title: 'Your operational data',
    body: 'Asset registers, work orders, IoT streams, SCADA feeds. The twin meets your existing systems where they live.',
    icon: 'plug',
    label: 'GIS · WMS · IoT · SCADA'
  }
];
---
<section class="relative" style="border-bottom: 1px solid var(--steel); background: var(--obsidian);">
  <div class="container-page py-24 md:py-32">
    <div class="chapter reveal">
      <span class="num">[ 02 ]</span>
      <span class="rule"></span>
      <span class="label">What feeds the twin</span>
    </div>

    <div class="grid lg:grid-cols-12 gap-10 items-end mb-16">
      <h2 class="lg:col-span-8 text-balance reveal">
        Real-world data. <em>Six high-fidelity streams</em>, fused into one model.
      </h2>
      <p class="lg:col-span-4 reveal" style="color: var(--fog); font-size: 17px; line-height: 1.6; transition-delay: 120ms;">
        The twin is only as good as the data underneath. We don't approximate the world — we ingest it.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-0 plate reveal" style="transition-delay: 200ms;">
      {sources.map((s, i) => {
        const col = i % 3;
        const row = Math.floor(i / 3);
        const styles = [
          col < 2 ? 'border-right: 1px solid var(--steel);' : '',
          row < 1 ? 'border-bottom: 1px solid var(--steel);' : ''
        ].join(' ');
        return (
        <article class="relative p-8 md:p-10" style={styles}>
          <div class="flex items-center justify-between mb-7">
            <span class="kicker" style="font-size: 10px;">Stream · {s.n}</span>
            <span class="kicker-accent" style="font-size: 10px;">{s.label}</span>
          </div>

          <!-- Brand-stroke icon -->
          <div class="mb-7 h-12 w-12 flex items-center justify-center" style="background: var(--obsidian-d); border: 1px solid var(--steel);">
            {s.icon === 'satellite' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5EE26B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="6" height="6"/>
                <line x1="6" y1="6" x2="9" y2="9"/>
                <line x1="18" y1="6" x2="15" y2="9"/>
                <line x1="6" y1="18" x2="9" y2="15"/>
                <line x1="18" y1="18" x2="15" y2="15"/>
                <circle cx="6" cy="6" r="1.5"/>
                <circle cx="18" cy="6" r="1.5"/>
                <circle cx="6" cy="18" r="1.5"/>
                <circle cx="18" cy="18" r="1.5"/>
              </svg>
            )}
            {s.icon === 'traffic' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5EE26B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 7 H17 L21 11 V17 H3 Z"/>
                <circle cx="7"  cy="17" r="1.8"/>
                <circle cx="17" cy="17" r="1.8"/>
                <line x1="3" y1="11" x2="13" y2="11"/>
              </svg>
            )}
            {s.icon === 'weather' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5EE26B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 14 a5 4 0 0 1 0 -8 a5 4 0 0 1 9.5 1.5 a3.5 3 0 0 1 1 5.5 H7 Z"/>
                <line x1="9"  y1="18" x2="9"  y2="22"/>
                <line x1="13" y1="18" x2="13" y2="22"/>
                <line x1="17" y1="18" x2="17" y2="22"/>
              </svg>
            )}
            {s.icon === 'mesh' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5EE26B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 8 L12 3 L21 8 V16 L12 21 L3 16 Z"/>
                <line x1="3"  y1="8"  x2="12" y2="13"/>
                <line x1="21" y1="8"  x2="12" y2="13"/>
                <line x1="12" y1="13" x2="12" y2="21"/>
              </svg>
            )}
            {s.icon === 'sim' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5EE26B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 12 q3 -5 6 0 t6 0 t6 0"/>
                <path d="M3 17 q3 -5 6 0 t6 0 t6 0" opacity="0.6"/>
                <path d="M3 7  q3 -5 6 0 t6 0 t6 0" opacity="0.4"/>
              </svg>
            )}
            {s.icon === 'plug' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5EE26B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 2 V6 M15 2 V6"/>
                <rect x="6" y="6" width="12" height="8" rx="1"/>
                <line x1="12" y1="14" x2="12" y2="18"/>
                <path d="M9 22 a3 3 0 0 1 6 0"/>
              </svg>
            )}
          </div>

          <h3 style="font-size: 1.375rem; line-height: 1.18;">{s.title}</h3>
          <p class="mt-4" style="color: var(--fog); line-height: 1.6;">{s.body}</p>
        </article>
        );
      })}
    </div>
  </div>
</section>
