---
// landing_page/src/components/home/Personas.astro
// "Who it's for" — three audience cards mirroring Branding §1 audience map.
// Each card: what the role sees in their daily Twin view + one operational outcome.
const personas = [
  {
    code: 'AUD · 01',
    audience: 'Transmission / distribution utilities',
    example:  'e.g., Hydro-Québec-class operator',
    sees: 'Span-level vegetation risk, ranked by 18-month outage probability, exportable to your work-management system.',
    cares: 'Outage avoidance · NERC FAC-003 audit · WMS integration',
    kpi:  { v: '–8 h', l: 'major outage · 9-quarter avg' },
    svg:  'queue'
  },
  {
    code: 'AUD · 02',
    audience: 'Municipalities & sustainability agencies',
    example:  'parks, public works, climate-resilience offices',
    sees: 'Every street tree as a queryable entity; canopy-cooling and equity scores by census block.',
    cares: 'Canopy targets · climate resilience · citizen-visible outcomes',
    kpi:  { v: '+4 %', l: 'canopy gain · 18 months · planting model' },
    svg:  'canopy'
  },
  {
    code: 'AUD · 03',
    audience: 'Platform-thesis investors',
    example:  'climate-tech, infrastructure, deep-tech',
    sees: 'One twin, multiple verticals, defensible data moat. Vegetation pays first; smart ops compounds.',
    cares: 'One model, many markets · capital efficiency · proof on hardest vertical',
    kpi:  { v: '$8 B', l: 'TAM · vegetation management · wedge' },
    svg:  'thesis'
  }
];
---
<section id="who-for" class="relative" style="border-bottom: 1px solid var(--steel); background: var(--obsidian);">
  <div class="container-page py-24 md:py-32">
    <div class="chapter reveal">
      <span class="num">[ 02 ]</span>
      <span class="rule"></span>
      <span class="label">Audience</span>
    </div>

    <div class="grid lg:grid-cols-12 gap-10 items-end mb-14">
      <h2 class="lg:col-span-8 text-balance reveal">
        Built for the people who <em>operate</em> large physical estates.
      </h2>
      <p class="lg:col-span-4 reveal" style="color: var(--fog); font-size: 17px; line-height: 1.6; transition-delay: 120ms;">
        Three audiences, three views, one twin underneath. Every claim on this page comes back to a number these readers care about.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-0 plate reveal" style="transition-delay: 200ms;">
      {personas.map((p, i) => (
        <article
          class={`relative p-8 md:p-10 group transition-colors duration-300 ${i < 2 ? 'lg:border-r' : ''} ${i < 2 ? 'border-b lg:border-b-0' : ''}`}
          style="border-color: var(--steel);"
        >
          <div class="flex items-center justify-between mb-6">
            <span class="kicker" style="font-size: 10px;">{p.code}</span>
            <span class="kicker-accent" style="font-size: 10px;">In production</span>
          </div>

          <!-- Mini specimen — branded data viz, no chartjunk -->
          <div class="aspect-[5/3] mb-7 overflow-hidden" style="background: var(--obsidian); border: 1px solid var(--steel);">
            <svg viewBox="0 0 200 120" class="w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
              {p.svg === 'queue' && (
                <g>
                  <rect width="200" height="120" fill="#0A0E14"/>
                  {[10, 28, 46, 64, 82, 100].map((y, i) => (
                    <g>
                      <rect x="8" y={y} width="184" height="10" fill="#1A2233"/>
                      <rect x="8" y={y} width={[120, 96, 72, 56, 36, 20][i]} height="10" fill={i < 2 ? '#5EE26B' : i < 4 ? '#46993F' : '#2D6630'} opacity={i < 2 ? 0.95 : 0.65}/>
                    </g>
                  ))}
                  <text x="14" y="18" font-family="JetBrains Mono,monospace" font-size="6" fill="#0A0E14">T1 · S-0042 · 0.96</text>
                  <text x="14" y="36" font-family="JetBrains Mono,monospace" font-size="6" fill="#0A0E14">T1 · S-0087 · 0.92</text>
                  <text x="14" y="54" font-family="JetBrains Mono,monospace" font-size="6" fill="#E6EAF0">T2 · S-0112 · 0.84</text>
                  <text x="14" y="72" font-family="JetBrains Mono,monospace" font-size="6" fill="#8B95A8">T3 · S-0203 · 0.71</text>
                  <text x="14" y="90" font-family="JetBrains Mono,monospace" font-size="6" fill="#8B95A8">T3 · S-0254 · 0.69</text>
                  <text x="14" y="108" font-family="JetBrains Mono,monospace" font-size="6" fill="#8B95A8">T4 · S-0311 · 0.53</text>
                </g>
              )}
              {p.svg === 'canopy' && (
                <g>
                  <rect width="200" height="120" fill="#0A0E14"/>
                  {Array.from({length: 50}).map((_, i) => {
                    const x = (i * 23 + 5) % 195 + 5;
                    const y = ((i * 13 + 7) % 110) + 5;
                    const r = 3 + (i % 4);
                    const fill = i % 6 === 0 ? '#5EE26B' : i % 4 === 0 ? '#46993F' : i % 3 === 0 ? '#2D6630' : '#1A3A1F';
                    return <circle cx={x} cy={y} r={r} fill={fill} opacity="0.95"/>;
                  })}
                  <path d="M40,40 L80,30 L120,50 L160,60 L190,50" stroke="#5EE26B" stroke-width="0.8" fill="none" stroke-dasharray="2 2"/>
                  <text x="6" y="112" font-family="JetBrains Mono,monospace" font-size="5" fill="#5EE26B">CANOPY · 38% → 42%</text>
                </g>
              )}
              {p.svg === 'thesis' && (
                <g>
                  <rect width="200" height="120" fill="#0A0E14"/>
                  {/* TAM stacked bars */}
                  <rect x="20" y="80" width="32" height="30" fill="#5EE26B"/>
                  <text x="22" y="76" font-family="JetBrains Mono,monospace" font-size="6" fill="#5EE26B">VEG</text>
                  <rect x="60" y="60" width="32" height="50" fill="#46993F"/>
                  <text x="62" y="56" font-family="JetBrains Mono,monospace" font-size="6" fill="#46993F">URBAN</text>
                  <rect x="100" y="40" width="32" height="70" fill="#2D6630"/>
                  <text x="102" y="36" font-family="JetBrains Mono,monospace" font-size="6" fill="#46993F">SMART OPS</text>
                  <rect x="140" y="20" width="32" height="90" fill="#1A3A1F"/>
                  <text x="142" y="16" font-family="JetBrains Mono,monospace" font-size="6" fill="#8B95A8">+ ADJ</text>
                  <line x1="6" y1="110" x2="194" y2="110" stroke="#3F4859" stroke-width="0.6"/>
                </g>
              )}
            </svg>
          </div>

          <p class="kicker-accent" style="font-size: 10px;">{p.example}</p>
          <h3 class="mt-3" style="font-size: 1.5rem; line-height: 1.2;">{p.audience}</h3>

          <p class="mt-5 text-sm" style="color: var(--fog); line-height: 1.55;">{p.sees}</p>

          <div class="mt-6 pt-5" style="border-top: 1px solid var(--steel);">
            <p class="kicker" style="font-size: 10px;">What they care about</p>
            <p class="mt-2 text-sm" style="color: var(--bone);">{p.cares}</p>
          </div>

          <div class="mt-6 flex items-baseline gap-3">
            <span class="font-display" style="font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; color: var(--chlorophyll);">{p.kpi.v}</span>
            <span class="kicker" style="font-size: 10px;">{p.kpi.l}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
