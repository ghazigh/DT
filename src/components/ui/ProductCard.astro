---
// landing_page/src/components/ui/ProductCard.astro
interface Props {
  href: string;
  name: string;
  tagline: string;
  stat: string;
  tam: string;
  badge?: string;
}
const { href, name, tagline, stat, tam, badge } = Astro.props;
---
<a
  href={href}
  class="group block rounded-2xl border border-line bg-bg-deep/40 p-8 no-underline hover:border-signal-mint/60 transition-colors"
>
  {badge && (
    <span class="inline-block font-mono text-xs uppercase tracking-widest text-signal-mint mb-3">
      {badge}
    </span>
  )}
  <h3 class="font-display text-2xl md:text-3xl text-ink-high">{name}</h3>
  <p class="mt-3 text-ink-mid">{tagline}</p>
  <dl class="mt-6 flex gap-6">
    <div>
      <dt class="text-mono-eyebrow">Headline</dt>
      <dd class="font-mono text-signal-ember text-lg mt-1">{stat}</dd>
    </div>
    <div>
      <dt class="text-mono-eyebrow">TAM</dt>
      <dd class="font-mono text-ink-high text-lg mt-1">{tam}</dd>
    </div>
  </dl>
  <span class="mt-6 inline-flex items-center gap-2 text-sm text-signal-ember group-hover:gap-3 transition-all">
    Learn more <span aria-hidden="true">→</span>
  </span>
</a>
