---
// landing_page/src/components/ui/FeatureCard.astro
interface Props {
  title: string;
  description: string;
  stat?: string;
}
const { title, description, stat } = Astro.props;
---
<article class="rounded-xl border border-line bg-bg-deep/40 p-6 flex flex-col gap-3">
  {stat && <p class="font-mono text-xs text-signal-ember">{stat}</p>}
  <h4 class="font-sans font-semibold text-lg text-ink-high">{title}</h4>
  <p class="text-sm">{description}</p>
</article>
