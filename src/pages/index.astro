---
import Layout         from '@/components/layout/Layout.astro';
import Hero           from '@/components/home/Hero.astro';
import HowTwinWorks   from '@/components/home/HowTwinWorks.astro';
import Inputs         from '@/components/home/Inputs.astro';
import PlatformArch   from '@/components/home/PlatformArch.astro';
import AgentLayer     from '@/components/home/AgentLayer.astro';
import TwinStudio     from '@/components/home/TwinStudio.astro';
import UseCases       from '@/components/home/UseCases.astro';
import Timeline90     from '@/components/home/Timeline90.astro';
import FooterCTA      from '@/components/home/FooterCTA.astro';
---
<Layout
  title="Sat Lab — A digital twin of the physical world. Talk to it."
  description="Sat Lab fuses satellites, traffic, weather, and high-fidelity simulations into one live model — then puts an agentic layer on top so you can query, simulate, and act on it in plain language."
>
  <Hero />
  <HowTwinWorks />
  <Inputs />
  <PlatformArch />
  <AgentLayer />
  <TwinStudio />
  <UseCases />
  <Timeline90 />
  <FooterCTA />
</Layout>
