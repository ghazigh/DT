---
import { getEntry } from 'astro:content';
import Layout       from '@/components/layout/Layout.astro';
import PageHero     from '@/components/layout/PageHero.astro';
import PageCTA      from '@/components/layout/PageCTA.astro';
import MapTeaser    from '@/components/interactive/MapTeaser';

const entry = await getEntry('products', 'urban-canopy');
if (!entry) throw new Error('Grid DT MDX missing');
const p = entry.data;

// Grid DT capability layers — what's stitched into the twin
const layers = [
  { code: '01', name: 'Terrain',     body: 'Cesium-streamed 3D terrain, 1-meter DEM, clipped to service area.', colour: '#4ca7ff' },
  { code: '02', name: 'Assets',      body: 'Poles, spans, substations, transformers — ingested from GIS, rendered as entities.', colour: '#4ca7ff' },
  { code: '03', name: 'Canopy',      body: 'Every tree inside and around the right-of-way, from Module 01 — as a queryable polygon.', colour: '#00ffa3' },
  { code: '04', name: 'Risk',        body: 'Live risk overlay, tier-coloured, zoomable from city to span to tree.', colour: '#ff6b3d' },
  { code: '05', name: 'Simulation',  body: 'Multi-physics hooks — heat, stormwater, carbon, wind — for scenario planning.', colour: '#a88bff' }
];

const metrics = [
  { value: '50M+',  label: 'Asset entities',        note: 'Streamed LoD · 60 fps browser' },
  { value: '≥95%',  label: 'Tree detection',        note: 'DBH > 10 cm, held-out test' },
  { value: '≥2°C',  label: 'Simulated cooling',     note: 'ENVI-met plugin, P3 objective' },
  { value: '≥85%',  label: 'Hazard recall',         note: 'XGBoost ensemble' }
];

const useCases = [
  { title: 'Operations control room',  body: 'One view of the grid. Crews, assets, risk, canopy — on a single 4K dashboard the ops team already trusts.' },
  { title: 'Storm scenario planning',  body: 'Run a wind event against the twin. See which spans are threatened, which feeders cascade, which crews pre-stage.' },
  { title: 'Municipal canopy planning',body: 'Cities use the same twin to plant where cooling, stormwater absorption, and equity need it most.' },
  { title: 'Carbon accounting',        body: 'Ecosystem services tallied tree-by-tree. Audit-ready carbon, defensible sustainability reports.' }
];
---
<Layout title={`Grid Digital Twin — Sat Lab`} description="A streaming 3D twin of the urban grid — terrain, assets, canopy, and risk as composable layers.">
  <PageHero
    eyebrow="[ MODULE · 02 · GRID DIGITAL TWIN ]"
    title={`A <em class="display-italic" style="color:#4ca7ff">living 3D model</em><br/>of the grid and everything<br/>around it.`}
    lede="The Grid DT is a streaming, city-scale twin. Terrain, buildings, power lines, sensors, and every vegetation polygon from Module 01 — all composable layers inside a single Cesium-rendered scene."
    accent="telemetry"
    ctas={[
      { href: '/contact?interest=partnership', label: 'Request a demo', style: 'primary' },
      { href: '#layers',                        label: 'See the layers', style: 'ghost' }
    ]}
  />

  <!-- Live map viewport + chrome -->
  <section class="relative border-b border-line">
    <div class="container-page py-20 md:py-24">
      <div class="flex items-center gap-3 mb-6">
        <span class="h-1.5 w-1.5 rounded-full animate-pulse-dot" style="background:#4ca7ff"></span>
        <span class="eyebrow" style="color:#4ca7ff">LIVE · TWIN VIEW · QUÉBEC SERVICE AREA</span>
        <span class="h-px flex-1 bg-line"></span>
        <span class="eyebrow hidden md:inline">46.85°N · 71.12°W · ZOOM 10</span>
      </div>

      <div class="relative aspect-[16/9] rounded-[20px] border border-line overflow-hidden bg-bg-carbon reveal">
        <MapTeaser client:visible />

        <div class="absolute inset-0 pointer-events-none">
          <span class="absolute top-3 left-3 h-4 w-4 border-l border-t" style="border-color:rgba(76,167,255,0.6)"></span>
          <span class="absolute top-3 right-3 h-4 w-4 border-r border-t" style="border-color:rgba(76,167,255,0.6)"></span>
          <span class="absolute bottom-3 left-3 h-4 w-4 border-l border-b" style="border-color:rgba(76,167,255,0.6)"></span>
          <span class="absolute bottom-3 right-3 h-4 w-4 border-r border-b" style="border-color:rgba(76,167,255,0.6)"></span>

          <div class="absolute top-0 inset-x-0 flex items-center justify-between px-5 py-3 bg-gradient-to-b from-bg-void/70 to-transparent">
            <div class="flex items-center gap-3">
              <span class="h-1.5 w-1.5 rounded-full animate-pulse-dot" style="background:#4ca7ff"></span>
              <span class="eyebrow" style="color:#4ca7ff">CORRIDOR 18 · RISK TIERS ACTIVE</span>
            </div>
            <span class="eyebrow hidden md:inline">STREAM · 60 FPS</span>
          </div>

          <div class="absolute bottom-0 inset-x-0 flex flex-wrap items-center justify-between gap-3 px-5 py-3 bg-gradient-to-t from-bg-void/80 to-transparent">
            <div class="flex items-center gap-4 font-mono text-[10px] uppercase tracking-[0.18em]">
              <span class="flex items-center gap-2"><span class="h-0.5 w-4 bg-signal-ember"></span>T1</span>
              <span class="flex items-center gap-2"><span class="h-0.5 w-4" style="background:#ffb047"></span>T2</span>
              <span class="flex items-center gap-2"><span class="h-0.5 w-4" style="background:#f5e44a"></span>T3</span>
              <span class="flex items-center gap-2"><span class="h-0.5 w-4 bg-signal-phosphor"></span>T4</span>
            </div>
            <span class="eyebrow">SYNTHETIC · NOT CLIENT DATA</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Layer stack -->
  <section id="layers" class="relative border-b border-line bg-bg-carbon/40">
    <div class="container-page py-28 md:py-36">
      <div class="max-w-2xl reveal">
        <p class="eyebrow" style="color:#4ca7ff">[ 01 / LAYER STACK ]</p>
        <h2 class="mt-6 text-balance">
          Five layers. <span class="display-italic" style="color:#4ca7ff">One streaming scene.</span>
        </h2>
        <p class="mt-8 text-ink-mid text-lg text-pretty">
          Each layer is independently queryable, independently updatable, and composable with the others. Toggle any, overlay any.
        </p>
      </div>

      <div class="mt-16 grid md:grid-cols-5 gap-px bg-line">
        {layers.map((l, i) => (
          <div class="bg-bg-void p-6 md:p-8 reveal" style={`transition-delay: ${i * 80}ms`}>
            <p class="font-mono text-[10px] uppercase tracking-[0.22em]" style={`color:${l.colour}`}>LAYER · {l.code}</p>
            <p class="mt-6 font-display text-2xl text-ink-paper leading-tight">{l.name}</p>
            <p class="mt-4 text-sm text-ink-mid leading-relaxed">{l.body}</p>
            <span class="mt-6 block h-0.5 w-8" style={`background:${l.colour}`}></span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pain -->
  <section class="relative border-b border-line">
    <div class="container-page py-28 md:py-36">
      <div class="grid md:grid-cols-12 gap-10 items-end">
        <div class="md:col-span-6 reveal">
          <p class="eyebrow" style="color:#ff6b3d">[ 02 / THE PAIN ]</p>
          <h2 class="mt-6 text-balance">
            Utilities and cities <span class="display-italic" style="color:#ff6b3d">are flying blind.</span>
          </h2>
        </div>
      </div>

      <div class="mt-16 grid gap-px bg-line md:grid-cols-3">
        {p.pain.map((item, i) => (
          <div class="bg-bg-void p-8 md:p-10 reveal" style={`transition-delay: ${i * 100}ms`}>
            <p class="font-display text-3xl md:text-4xl leading-tight text-ink-paper">{item.headline}</p>
            <p class="mt-6 text-ink-mid text-[15px] leading-relaxed">{item.body}</p>
            <p class="mt-6 eyebrow !text-ink-faint">SRC · {item.source}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="relative border-b border-line bg-bg-carbon/40">
    <div class="container-page py-28 md:py-36">
      <div class="max-w-2xl reveal">
        <p class="eyebrow" style="color:#4ca7ff">[ 03 / USE CASES ]</p>
        <h2 class="mt-6 text-balance">
          Four rooms where <span class="display-italic" style="color:#4ca7ff">the twin lives.</span>
        </h2>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2">
        {useCases.map((uc, i) => (
          <article class="card-elev p-8 md:p-10 reveal" style={`transition-delay: ${i * 100}ms`}>
            <p class="eyebrow" style="color:#4ca7ff">CASE · {String(i + 1).padStart(2, '0')}</p>
            <h3 class="mt-6 font-display text-[1.6rem] text-ink-paper leading-tight">{uc.title}</h3>
            <p class="mt-5 text-ink-mid text-[15px] leading-relaxed">{uc.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Metrics -->
  <section class="relative border-b border-line">
    <div class="container-page py-28 md:py-36">
      <div class="max-w-2xl reveal">
        <p class="eyebrow" style="color:#4ca7ff">[ 04 / METRICS ]</p>
        <h2 class="mt-6 text-balance">
          What the twin <span class="display-italic" style="color:#4ca7ff">delivers.</span>
        </h2>
      </div>

      <div class="mt-16 grid gap-px bg-line md:grid-cols-4">
        {metrics.map((m, i) => (
          <div class="bg-bg-void p-8 md:p-10 reveal" style={`transition-delay: ${i * 80}ms`}>
            <p class="font-display text-5xl md:text-6xl leading-none" style="color:#4ca7ff">{m.value}</p>
            <p class="mt-6 text-ink-paper text-[15px] leading-snug">{m.label}</p>
            <p class="mt-3 eyebrow !text-ink-faint">{m.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PageCTA
    eyebrow="[ 05 / NEXT ]"
    headline={`Want the <em class="display-italic" style="color:#4ca7ff">live demo?</em>`}
    subhead="We'll run through the full twin in your service area — terrain, assets, risk, canopy — in a 30-minute session."
    primaryHref="/contact?interest=partnership"
    primaryLabel={p.ctaLabel}
    secondaryHref="/vegetation"
    secondaryLabel="See Module 01"
  />
</Layout>
