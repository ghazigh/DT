---
import Layout            from '@/components/layout/Layout.astro';
import VegetationHero    from '@/components/home/VegetationHero.astro';
import HowItWorks        from '@/components/home/HowItWorks.astro';
import Proof             from '@/components/home/Proof.astro';
import LiveMap           from '@/components/home/LiveMap.astro';
import BeforeAfter       from '@/components/home/BeforeAfter.astro';
import ProductUI         from '@/components/home/ProductUI.astro';
import VegetationStudio  from '@/components/home/VegetationStudio.astro';
import Timeline90        from '@/components/home/Timeline90.astro';
import FooterCTA         from '@/components/home/FooterCTA.astro';
---
<Layout
  title="Sat Lab · Vegetation management — Stop trees from taking down your power lines."
  description="Module 01 on the Sat Lab twin. Find every tree about to hit your power lines. Rank them by risk. Trim what matters first."
>
  <VegetationHero />
  <HowItWorks />
  <Proof />
  <LiveMap />
  <BeforeAfter />
  <ProductUI />
  <VegetationStudio />
  <Timeline90 />
  <FooterCTA />
</Layout>
