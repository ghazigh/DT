---
// landing_page/src/pages/themes.astro
// Side-by-side preview of three rebranding directions.
// Each theme is fully self-contained CSS (scoped by wrapper class) so
// nothing leaks globally. Pick one — we then apply it site-wide.
import '../styles/globals.css';
import '@fontsource-variable/bricolage-grotesque/index.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Three Directions — Sat Lab Rebranding</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <style is:global>
      /* --------- Page chrome (neutral shell around the three theme cards) --------- */
      html, body { background: #0a0a0a; color: #f4f4f0; }
      body { font-family: 'Inter Tight', system-ui, sans-serif; }

      .shell-nav {
        position: fixed;
        top: 0; inset-inline: 0;
        z-index: 100;
        background: rgba(10,10,10,0.82);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }
      .shell-nav-inner {
        max-width: 1600px; margin: 0 auto; padding: 14px 32px;
        display: flex; align-items: center; justify-content: space-between;
        font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase;
      }
      .shell-nav a { color: #f4f4f0; text-decoration: none; opacity: 0.75; transition: opacity 0.2s; }
      .shell-nav a:hover { opacity: 1; }
      .shell-nav .chips { display: flex; gap: 8px; }
      .shell-nav .chip {
        padding: 8px 14px; border: 1px solid rgba(255,255,255,0.15); border-radius: 999px;
        font-size: 10px; letter-spacing: 0.2em; cursor: pointer;
        transition: all 0.25s;
      }
      .shell-nav .chip:hover { border-color: #f4f4f0; }
      .shell-nav .chip.active { background: #f4f4f0; color: #0a0a0a; border-color: #f4f4f0; }

      .shell-intro {
        max-width: 1200px; margin: 0 auto; padding: 140px 32px 60px;
        text-align: center;
      }
      .shell-intro .eyebrow {
        font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
        color: rgba(255,255,255,0.55);
      }
      .shell-intro h1 {
        font-family: 'Instrument Serif', serif;
        font-size: clamp(40px, 6vw, 84px);
        line-height: 1;
        margin: 24px 0 16px;
        font-weight: 400;
      }
      .shell-intro h1 em { font-style: italic; color: #ff8a3d; }
      .shell-intro p {
        color: rgba(255,255,255,0.6); max-width: 620px; margin: 0 auto;
        font-size: 17px; line-height: 1.55;
      }

      .theme-wrap {
        position: relative;
        margin: 40px auto 0;
        max-width: 1680px;
        padding: 0 32px 100px;
      }
      .theme-header {
        display: grid; grid-template-columns: auto 1fr auto; align-items: baseline;
        gap: 24px;
        padding: 32px 0 18px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
      }
      .theme-number {
        font-family: 'Instrument Serif', serif; font-style: italic;
        font-size: 56px; color: rgba(255,255,255,0.3); line-height: 1;
      }
      .theme-meta { color: rgba(255,255,255,0.7); font-size: 13px; display: flex; gap: 20px; flex-wrap: wrap; }
      .theme-meta strong { color: #f4f4f0; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; font-size: 11px; }
      .theme-swatch {
        display: inline-block; width: 18px; height: 18px; border-radius: 4px; margin-right: 6px;
        vertical-align: middle; border: 1px solid rgba(255,255,255,0.15);
      }
      .theme-card {
        margin-top: 0;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 40px 120px rgba(0,0,0,0.5);
      }
      .theme-choose {
        margin-top: 28px; display: flex; gap: 24px; align-items: center;
        font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase;
      }
      .theme-choose a {
        display: inline-flex; align-items: center; gap: 10px;
        padding: 14px 24px; border: 1px solid #f4f4f0;
        color: #f4f4f0; text-decoration: none;
        background: transparent; transition: all 0.3s;
      }
      .theme-choose a:hover { background: #f4f4f0; color: #0a0a0a; }
      .theme-choose .hint { opacity: 0.4; }

      /* ============================================================ */
      /*  01 · OBSERVATORY — minimalist + technology                  */
      /*  Pure white, grotesk, one precision accent (tunable)          */
      /* ============================================================ */
      .theme-obs {
        --obs-accent: #e85400;
        background: #ffffff;
        color: #0a0a0a;
        font-family: 'Inter Tight', system-ui, sans-serif;
        padding: 0;
      }
      .theme-obs * { box-sizing: border-box; }
      .theme-obs .bar {
        border-bottom: 1px solid #0a0a0a;
        display: grid; grid-template-columns: 1fr auto auto auto auto 1fr;
        align-items: center;
        font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
        padding: 20px 32px;
        gap: 40px;
      }
      .theme-obs .bar > *:first-child { font-weight: 600; letter-spacing: -0.02em; text-transform: none; font-size: 15px; }
      .theme-obs .hero {
        padding: 120px 32px 80px;
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
      }
      .theme-obs .kicker {
        grid-column: 1 / 4;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px; letter-spacing: 0.12em;
        display: flex; gap: 16px; align-items: center;
        opacity: 0.65;
      }
      .theme-obs .kicker .tick { display: inline-block; width: 8px; height: 8px; background: var(--obs-accent); border-radius: 50%; transition: background 0.3s; }
      .theme-obs h1, .theme-obs h2, .theme-obs h3, .theme-obs h4 {
        font-family: 'Inter Tight', system-ui, sans-serif;
      }
      .theme-obs h1 {
        grid-column: 1 / 11;
        font-size: clamp(48px, 7vw, 108px);
        line-height: 0.95;
        letter-spacing: -0.04em;
        font-weight: 600;
        margin: 56px 0 0;
      }
      .theme-obs h1 .dim { color: rgba(10,10,10,0.3); }
      .theme-obs h1 .mark { color: var(--obs-accent); transition: color 0.3s; }
      .theme-obs .desc {
        grid-column: 1 / 6;
        margin-top: 48px;
        font-size: 16px; line-height: 1.5;
        color: rgba(10,10,10,0.65);
      }
      .theme-obs .ctas {
        grid-column: 7 / 13;
        margin-top: 48px;
        display: flex; align-items: flex-end; justify-content: flex-end; gap: 16px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
      }
      .theme-obs .btn {
        display: inline-flex; align-items: center; gap: 10px;
        padding: 14px 18px; border: 1px solid #0a0a0a;
        color: #0a0a0a; text-decoration: none;
      }
      .theme-obs .btn--fill { background: #0a0a0a; color: #fff; }
      .theme-obs .btn--fill:hover { background: var(--obs-accent); border-color: var(--obs-accent); }

      .theme-obs .rule { border-top: 1px solid #0a0a0a; }

      .theme-obs .proof {
        padding: 80px 32px;
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
      }
      .theme-obs .proof .label {
        grid-column: 1 / 4;
        font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em;
        color: var(--obs-accent); text-transform: uppercase;
        padding-top: 12px;
        transition: color 0.3s;
      }
      .theme-obs .proof .figure {
        grid-column: 4 / 11;
        font-size: clamp(90px, 14vw, 220px);
        font-weight: 400;
        line-height: 0.85;
        letter-spacing: -0.06em;
      }
      .theme-obs .proof .figure .pct { color: var(--obs-accent); transition: color 0.3s; }
      .theme-obs .proof .note {
        grid-column: 11 / 13;
        font-family: 'JetBrains Mono', monospace; font-size: 11px; line-height: 1.5;
        align-self: end;
        color: rgba(10,10,10,0.5);
      }
      .theme-obs .proof-metrics {
        grid-column: 1 / 13;
        margin-top: 60px;
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;
        border-top: 1px solid rgba(10,10,10,0.15);
        padding-top: 24px;
      }
      .theme-obs .proof-metrics .m { display: grid; gap: 8px; }
      .theme-obs .proof-metrics .n { font-size: 40px; font-weight: 500; letter-spacing: -0.03em; }
      .theme-obs .proof-metrics .l { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(10,10,10,0.55); }

      .theme-obs .diagram {
        padding: 60px 32px 80px;
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 0;
        border-top: 1px solid #0a0a0a;
      }
      .theme-obs .diagram > div { padding: 32px; border-right: 1px solid rgba(10,10,10,0.15); }
      .theme-obs .diagram > div:last-child { border-right: none; }
      .theme-obs .diagram .module { grid-column: span 4; }
      .theme-obs .diagram .core { grid-column: span 4; background: #f7f3ea; }
      .theme-obs .diagram h3 { font-size: 26px; font-weight: 500; letter-spacing: -0.02em; margin: 20px 0 12px; }
      .theme-obs .diagram .tag { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em; color: var(--obs-accent); text-transform: uppercase; transition: color 0.3s; }
      .theme-obs .diagram p { font-size: 14px; line-height: 1.55; color: rgba(10,10,10,0.65); margin: 0; }

      /* Accent picker — sits above the Observatory card */
      .accent-picker {
        display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
        padding: 16px 20px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        margin: 16px 0 18px;
      }
      .accent-picker .pick-label {
        font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
        color: rgba(255,255,255,0.55);
      }
      .accent-picker .swatches { display: flex; gap: 10px; flex-wrap: wrap; }
      .accent-picker button {
        display: inline-flex; align-items: center; gap: 10px;
        padding: 8px 14px 8px 8px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 999px;
        color: #f4f4f0; cursor: pointer;
        font-size: 12px; letter-spacing: 0.05em;
        font-family: inherit;
        transition: all 0.25s;
      }
      .accent-picker button:hover { border-color: rgba(255,255,255,0.4); }
      .accent-picker button.on { background: rgba(255,255,255,0.12); border-color: #f4f4f0; }
      .accent-picker button .dot {
        width: 18px; height: 18px; border-radius: 50%;
        border: 1px solid rgba(0,0,0,0.15);
      }
      .accent-picker .code {
        font-family: 'JetBrains Mono', monospace; font-size: 10px;
        color: rgba(255,255,255,0.5); letter-spacing: 0.05em;
      }

      /* ============================================================ */
      /*  02 · ATLAS — creative + modern                               */
      /*  Cream paper, contrasted serif, brass + barn red              */
      /* ============================================================ */
      .theme-atl {
        background: #f0e8d8;
        color: #0e1b18;
        font-family: 'Inter Tight', system-ui, sans-serif;
      }
      .theme-atl .bar {
        padding: 24px 40px;
        display: flex; align-items: baseline; justify-content: space-between;
        border-bottom: 1px solid rgba(14,27,24,0.15);
      }
      .theme-atl .mark {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: 26px; letter-spacing: -0.02em;
        font-weight: 400;
      }
      .theme-atl .mark em { color: #9c3a2a; font-style: italic; }
      .theme-atl .nav {
        display: flex; gap: 32px;
        font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
      }
      .theme-atl .nav a { color: rgba(14,27,24,0.75); text-decoration: none; }
      .theme-atl .nav a:hover { color: #9c3a2a; }

      .theme-atl .hero {
        position: relative;
        padding: 100px 40px 120px;
        overflow: hidden;
      }
      .theme-atl .hero::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 60% 80% at 85% 40%, rgba(184,137,58,0.28) 0%, transparent 65%);
        pointer-events: none;
      }
      .theme-atl .vol {
        font-family: 'Fraunces', serif; font-style: italic;
        font-size: 14px; color: rgba(14,27,24,0.55);
        letter-spacing: -0.01em;
      }
      .theme-atl .vol::before { content: ''; display: inline-block; width: 48px; height: 1px; background: rgba(14,27,24,0.4); margin-right: 16px; vertical-align: 4px; }
      .theme-atl h1, .theme-atl h2, .theme-atl h3, .theme-atl h4 {
        font-family: 'Fraunces', Georgia, serif;
      }
      .theme-atl h1 {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 300;
        font-size: clamp(56px, 10vw, 156px);
        line-height: 0.88;
        letter-spacing: -0.035em;
        margin: 36px 0 0;
        max-width: 1200px;
        position: relative;
      }
      .theme-atl h1 em { font-style: italic; font-weight: 300; color: #9c3a2a; }
      .theme-atl h1 .ochre { color: #b8893a; font-style: italic; }
      .theme-atl .hero .meta {
        margin-top: 72px;
        display: grid; grid-template-columns: 1fr 1fr auto; gap: 60px; align-items: end;
        max-width: 1000px; position: relative;
      }
      .theme-atl .hero .desc {
        font-size: 18px; line-height: 1.5;
        color: rgba(14,27,24,0.75);
      }
      .theme-atl .hero .desc em { font-style: italic; color: #9c3a2a; }
      .theme-atl .btn {
        display: inline-flex; align-items: center; gap: 14px;
        padding: 18px 28px; background: #0e1b18; color: #f0e8d8;
        font-size: 12px; letter-spacing: 0.28em; text-transform: uppercase;
        text-decoration: none;
        transition: background 0.4s;
      }
      .theme-atl .btn:hover { background: #9c3a2a; }

      .theme-atl .plate {
        position: relative;
        margin: 0 40px;
        border-top: 1px solid rgba(14,27,24,0.15);
        border-bottom: 1px solid rgba(14,27,24,0.15);
        padding: 80px 0;
      }
      .theme-atl .plate-head {
        display: grid; grid-template-columns: auto 1fr; gap: 24px; margin-bottom: 48px;
        align-items: baseline;
      }
      .theme-atl .plate-num { font-family: 'Fraunces', serif; font-style: italic; font-size: 22px; color: rgba(14,27,24,0.5); }
      .theme-atl .plate-kicker { font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #9c3a2a; }

      .theme-atl .plate .spread {
        display: grid; grid-template-columns: 2fr 1fr; gap: 60px; align-items: end;
      }
      .theme-atl .plate .title {
        font-family: 'Fraunces', serif; font-weight: 300;
        font-size: clamp(44px, 6vw, 88px);
        line-height: 0.95; letter-spacing: -0.025em;
      }
      .theme-atl .plate .title em { font-style: italic; color: #9c3a2a; }

      .theme-atl .plate .caption {
        font-family: 'Fraunces', serif; font-style: italic;
        font-size: 16px; line-height: 1.55; color: rgba(14,27,24,0.7);
      }

      /* "Specimen" — layered canopy plate */
      .theme-atl .specimen {
        margin-top: 48px;
        position: relative;
        height: 360px;
        overflow: hidden;
        background: #ddd0b2;
        border: 1px solid rgba(14,27,24,0.12);
      }
      .theme-atl .specimen svg { position: absolute; inset: 0; width: 100%; height: 100%; }
      .theme-atl .specimen-caption {
        display: flex; justify-content: space-between;
        margin-top: 12px;
        font-family: 'Fraunces', serif; font-style: italic;
        font-size: 14px; color: rgba(14,27,24,0.6);
      }

      /* ============================================================ */
      /*  03 · SIGNAL — modern + creative + technology                 */
      /*  Warm off-white, giant wide grotesk, electric ultramarine     */
      /* ============================================================ */
      .theme-sig {
        background: #ede8e1;
        color: #111;
        font-family: 'Bricolage Grotesque Variable', 'Inter Tight', system-ui, sans-serif;
      }
      .theme-sig .bar {
        padding: 24px 36px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .theme-sig .mark {
        font-family: 'Bricolage Grotesque Variable', sans-serif;
        font-variation-settings: 'wdth' 125, 'wght' 800, 'opsz' 22;
        font-size: 24px; letter-spacing: -0.04em;
      }
      .theme-sig .nav { display: flex; gap: 24px; font-size: 13px; font-weight: 500; }
      .theme-sig .nav a { color: #111; text-decoration: none; }
      .theme-sig .nav a:hover { color: #3b46ff; }
      .theme-sig .enquire {
        background: #3b46ff; color: #ede8e1;
        padding: 10px 18px; border-radius: 999px;
        font-weight: 600; font-size: 13px; text-decoration: none;
      }
      .theme-sig .enquire:hover { background: #111; }

      .theme-sig h1, .theme-sig h2, .theme-sig h3, .theme-sig h4 {
        font-family: 'Bricolage Grotesque Variable', 'Inter Tight', sans-serif;
      }
      .theme-sig .hero { padding: 60px 36px 0; position: relative; }
      .theme-sig .hero-kicker {
        display: inline-flex; align-items: center; gap: 10px;
        font-size: 13px; font-weight: 500;
        padding: 8px 16px; background: #111; color: #ede8e1; border-radius: 999px;
        margin-bottom: 32px;
      }
      .theme-sig .hero-kicker::before { content: ''; display: inline-block; width: 8px; height: 8px; background: #3b46ff; border-radius: 50%; }

      .theme-sig .type-hero {
        position: relative;
        font-family: 'Bricolage Grotesque Variable', sans-serif;
        font-variation-settings: 'wdth' 125, 'wght' 900, 'opsz' 96;
        font-size: clamp(70px, 15vw, 260px);
        line-height: 0.82;
        letter-spacing: -0.08em;
        color: #111;
      }
      .theme-sig .type-hero .word {
        display: inline-block;
      }
      .theme-sig .type-hero .twin {
        color: #3b46ff;
        display: inline-block;
        transform: translateY(0);
      }
      .theme-sig .type-hero .slash {
        font-variation-settings: 'wdth' 75, 'wght' 900;
        color: rgba(17,17,17,0.2);
      }

      .theme-sig .hero-row {
        display: grid; grid-template-columns: 1fr 1fr; gap: 40px;
        margin-top: 48px;
      }
      .theme-sig .hero-desc { font-size: 19px; line-height: 1.45; max-width: 500px; }
      .theme-sig .hero-desc strong { color: #3b46ff; }
      .theme-sig .hero-ctas { display: flex; gap: 16px; align-items: flex-start; justify-content: flex-end; }
      .theme-sig .hero-cta-primary {
        background: #111; color: #ede8e1;
        padding: 18px 28px; border-radius: 999px;
        font-weight: 600; font-size: 14px; text-decoration: none;
        display: inline-flex; align-items: center; gap: 12px;
      }
      .theme-sig .hero-cta-primary:hover { background: #3b46ff; }
      .theme-sig .hero-cta-ghost {
        color: #111; padding: 18px 4px;
        font-weight: 500; font-size: 14px; text-decoration: none;
        border-bottom: 2px solid #111;
      }

      /* Poster grid — color-blocked module cards */
      .theme-sig .poster {
        margin-top: 80px;
        display: grid; grid-template-columns: 1fr 1fr; gap: 4px;
      }
      .theme-sig .card-signal {
        padding: 48px 36px 36px;
        border-radius: 16px;
        position: relative;
        overflow: hidden;
      }
      .theme-sig .card-signal.blue { background: #3b46ff; color: #ede8e1; }
      .theme-sig .card-signal.cream { background: #111; color: #ede8e1; }
      .theme-sig .card-signal .tag {
        font-size: 11px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.8;
      }
      .theme-sig .card-signal h3 {
        font-family: 'Bricolage Grotesque Variable', sans-serif;
        font-variation-settings: 'wdth' 115, 'wght' 800, 'opsz' 72;
        font-size: clamp(44px, 6vw, 88px);
        line-height: 0.9; letter-spacing: -0.04em;
        margin: 16px 0 20px;
      }
      .theme-sig .card-signal p { font-size: 16px; line-height: 1.5; max-width: 380px; opacity: 0.9; }
      .theme-sig .card-signal .arrow {
        position: absolute; right: 28px; bottom: 28px;
        width: 56px; height: 56px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        background: rgba(255,255,255,0.15);
        font-size: 24px;
      }
      .theme-sig .card-signal.cream .arrow { background: #3b46ff; color: #ede8e1; }

      /* Big proof block as bright graphic */
      .theme-sig .proof {
        margin-top: 80px;
        padding: 60px 36px 80px;
        background: #3b46ff;
        color: #ede8e1;
        border-radius: 16px;
        display: grid; grid-template-columns: 2fr 1fr; gap: 60px; align-items: end;
      }
      .theme-sig .proof .fig {
        font-family: 'Bricolage Grotesque Variable', sans-serif;
        font-variation-settings: 'wdth' 125, 'wght' 800, 'opsz' 96;
        font-size: clamp(100px, 16vw, 240px);
        line-height: 0.82; letter-spacing: -0.07em;
      }
      .theme-sig .proof .fig .pct { color: #ede8e1; font-variation-settings: 'wdth' 75, 'wght' 900; }
      .theme-sig .proof .body p {
        font-size: 15px; line-height: 1.5; opacity: 0.85; margin: 0 0 16px;
      }
      .theme-sig .proof .body .label {
        font-size: 11px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase;
        margin-bottom: 12px;
      }

      @media (max-width: 900px) {
        .theme-obs .hero, .theme-obs .proof { display: block; }
        .theme-atl .hero .meta { grid-template-columns: 1fr; }
        .theme-atl .plate .spread { grid-template-columns: 1fr; }
        .theme-sig .hero-row { grid-template-columns: 1fr; }
        .theme-sig .poster { grid-template-columns: 1fr; }
