    <!-- Smooth-scroll chip activation + choose handler -->
    <script is:inline>
      const chips = document.querySelectorAll('.shell-nav .chip');
      const sections = document.querySelectorAll('section.theme-wrap');

      chips.forEach(c => c.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.querySelector(c.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }));

      // Scroll spy
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            chips.forEach(c => {
              const match = c.getAttribute('href') === '#' + id;
              c.classList.toggle('active', match);
            });
          }
        });
      }, { rootMargin: '-40% 0px -40% 0px' });
      sections.forEach(s => io.observe(s));

      // Accent picker — live-swap the Observatory accent
      const obsCard = document.getElementById('obs-card');
      const picker = document.getElementById('accent-picker');
      if (obsCard && picker) {
        picker.querySelectorAll('button[data-accent]').forEach(btn => {
          btn.addEventListener('click', () => {
            const hex = btn.getAttribute('data-accent');
            obsCard.style.setProperty('--obs-accent', hex);
            picker.querySelectorAll('button').forEach(b => b.classList.remove('on'));
            btn.classList.add('on');

            // Also update the Observatory swatch in the theme-header
            const swatchRow = document.querySelector('#observatory .theme-meta');
            if (swatchRow) {
              const swatches = swatchRow.querySelectorAll('.theme-swatch');
              if (swatches[2]) swatches[2].style.background = hex;
            }
            // Update the "Choose Observatory" link to include the accent choice
            const choose = document.querySelector('[data-theme="observatory"]');
            if (choose) choose.setAttribute('data-accent', hex);
          });
        });
      }

      // Choose handler — just confirms the pick for now
      document.querySelectorAll('[data-theme]').forEach(a => {
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const theme = a.getAttribute('data-theme');
          const accent = a.getAttribute('data-accent') || '';
          const msg = accent
            ? `Apply the ${theme.toUpperCase()} theme with accent ${accent}?`
            : `Apply the ${theme.toUpperCase()} theme site-wide?`;
          const confirmed = confirm(msg + '\n\nClick OK to confirm, then tell the assistant.');
          if (confirmed) {
            const tell = accent
              ? `Apply the ${theme} theme with accent ${accent}`
              : `Apply the ${theme} theme`;
            alert(`Got it.\n\nTell the assistant: "${tell}"`);
          }
        });
      });
    </script>
